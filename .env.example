NODE_ENV=development     # production | development

PORT=5000                # Puerto del servidor

# JWT
JWT_SECRET=              # Secreto para firmar tokens JWT (obligatorio al iniciar)

# Base de datos — valores obtenidos desde Supabase Dashboard > Project Settings > Database
DB_HOST=                 # ej: db.xxxxxxxxxxxx.supabase.co
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=             # Contraseña definida al crear el proyecto en Supabase
DB_NAME=postgres

# CORS
FRONTEND_URL=            # URL del frontend permitida por CORS (ej: http://localhost:3000)

# Email SMTP
RESEND_API_KEY=re_xxxxxxxxxxxx    # desde dashboard.resend.com/api-keys
RESEND_FROM=onboarding@resend.dev # en desarrollo (sin dominio propio)
APP_URL=http://localhost:5000      # base URL del backend