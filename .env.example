NODE_ENV=development     # production | development

PORT=5000                # Puerto del servidor

# JWT
JWT_SECRET=              # Secreto para firmar access tokens JWT — expiran en 15 min
JWT_REFRESH_SECRET=      # Secreto para firmar refresh tokens JWT — expiran en 7 días (debe ser distinto a JWT_SECRET)

# Base de datos
# development: contenedor Docker → DB_PORT=5433 (5432 reservado para PostgreSQL local)
# production:  valores desde Supabase Dashboard > Project Settings > Database
DB_HOST=localhost         # prod: ej: db.xxxxxxxxxxxx.supabase.co
DB_PORT=5434              # prod: 5432
DB_USER=postgres
DB_PASSWORD=              # prod: contraseña definida al crear el proyecto en Supabase
DB_NAME=ataxchile_dev     # prod: postgres

# CORS
FRONTEND_URL=            # URL del frontend permitida por CORS (ej: http://localhost:3000)

# Email SMTP
RESEND_API_KEY=re_xxxxxxxxxxxx    # desde dashboard.resend.com/api-keys
RESEND_FROM=onboarding@resend.dev # en desarrollo (sin dominio propio)
APP_URL=http://localhost:5000      # base URL del backend